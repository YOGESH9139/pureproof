    ec_add BN254g1
    // NexusVerifierLogicSig.py:324
    // quotient = invert(quotient)
    swap
    callsub invert
    // NexusVerifierLogicSig.py:331
    // check = ec.pairing_check(EC.BN254g1, digest + quotient, g2)
    concat
    // NexusVerifierLogicSig.py:326-329
