    return


// NexusVerifierLogicSig.expmod(base: bytes, exponent: bytes, modulus: bytes) -> bytes:
expmod:
    // NexusVerifierLogicSig.py:336-337
    // @subroutine
    // def expmod(base: BigUInt, exponent: BigUInt, modulus: BigUInt) -> BigUInt:
    proto 3 1
    // NexusVerifierLogicSig.py:339
    // result = BigUInt(1)
    bytec_1 // 0x01

expmod_while_top@1:
    // NexusVerifierLogicSig.py:340
    // while exponent > 0:
    frame_dig -2
    bytec_2 // 0x
    b>
    bz expmod_after_while@5
    // NexusVerifierLogicSig.py:341
    // if exponent % 2 == 1:
    frame_dig -2
    pushbytes 0x02
    b%
    bytec_1 // 0x01
    b==
    bz expmod_after_if_else@4
    // NexusVerifierLogicSig.py:342
    // result = (result * base) % modulus
    frame_dig 0
    frame_dig -3
    b*
    frame_dig -1
    b%
    frame_bury 0

expmod_after_if_else@4:
    // NexusVerifierLogicSig.py:343
    // exponent = exponent // 2
    frame_dig -2
    pushbytes 0x02
    b/
    frame_bury -2
    // NexusVerifierLogicSig.py:344
    // base = (base * base) % modulus
    frame_dig -3
    dup
    b*
    frame_dig -1
    b%
    frame_bury -3
    b expmod_while_top@1

expmod_after_while@5:
    // NexusVerifierLogicSig.py:345
    // return result
    frame_dig 0
    swap
    retsub


// NexusVerifierLogicSig.invert(p: bytes) -> bytes:
invert:
    // NexusVerifierLogicSig.py:352-353
    // @subroutine
    // def invert(p : Bytes) -> Bytes:
    proto 1 1
    // NexusVerifierLogicSig.py:355
    // x = p[:32]
    frame_dig -1
    len
    intc_0 // 32
    dig 1
    >=
    intc_0 // 32
    dig 2
    uncover 2
    select
    frame_dig -1
    intc_1 // 0
    dig 2
    substring3
    cover 2
    // NexusVerifierLogicSig.py:356
    // y = BigUInt.from_bytes(p[32:])
    frame_dig -1
    swap
    uncover 2
    substring3
    dup
    // NexusVerifierLogicSig.py:357
    // if y == BigUInt(0):
    bytec_2 // 0x
    b==
    bz invert_after_if_else@2
    // NexusVerifierLogicSig.py:358
    // return p
    frame_dig -1
    frame_bury 0
    retsub

invert_after_if_else@2:
    // NexusVerifierLogicSig.py:359
    // neg_y = BigUInt(P_MOD) - y
    pushbytes 0x30644e72e131a029b85045b68181585d97816a916871ca8d3c208c16d87cfd47
    frame_dig 1
    b-
    // NexusVerifierLogicSig.py:360
    // return x + UInt256(neg_y).bytes
    dup
    len
    intc_0 // 32
    <=
    assert // overflow
    intc_0 // 32
    bzero
    b|
    frame_dig 0
    swap
    concat
    frame_bury 0
    retsub
